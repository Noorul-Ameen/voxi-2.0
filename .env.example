# Optional public override. Blank uses the EU-residency fallback in vite.config.js.
VITE_AGENT_ID=
VITE_API_ONLY=true
VITE_VISTA_BASE=/api/vox
VITE_VISTA_PRICING_PATH=/api/booking/quote
VITE_VISTA_RESERVATION_PATH=/api/booking/reserve
VITE_VISTA_PROGRAMMING_DAYS=9

# Server-only VOX/Vista credentials. Never prefix these with VITE_.
VOX_AUTH_URL=https://your-development-host/v1/oauth/generate?grant_type=client_credentials
VOX_API_BASE_URL=https://your-development-host/vistatickets/vista/v2
VOX_BASIC_CREDENTIAL=
VOX_API_KEY=
VOX_SALES_CHANNEL=WWW
VOX_TOKEN_REFRESH_SKEW_SECONDS=60
VOX_REQUEST_TIMEOUT_MS=15000
VOX_ENABLE_ORDER_WRITES=false
